{
  "name": "@mhauens/workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace for independently versioned web component packages.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "pnpm -r --filter ./packages/* build",
    "build:demo": "vite build",
    "preview": "pnpm build:demo && vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:package": "node ./scripts/release-package.mjs"
  },
  "keywords": [
    "web-components",
    "storybook",
    "vite",
    "typescript"
  ],
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/web-components": "^8.6.18",
    "@storybook/web-components-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^0.12.0",
    "globals": "^16.5.0",
    "happy-dom": "^17.6.3",
    "prettier": "^3.8.1",
    "storybook": "^8.6.18",
    "typescript": "~5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
