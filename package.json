{
  "name": "@mhauens/workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace for independently versioned web component packages.",
  "license": "MIT",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "pnpm -r --filter ./packages/* build",
    "test": "vitest run -c vitest.config.ts --project unit",
    "test:watch": "vitest -c vitest.config.ts --project unit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:package": "node ./scripts/release-package.mjs"
  },
  "keywords": [
    "web-components",
    "storybook",
    "vite",
    "typescript"
  ],
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/web-components": "^10.3.5",
    "@storybook/web-components-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
