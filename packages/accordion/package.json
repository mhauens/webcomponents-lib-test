  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json"
  },
  "keywords": [
    "web-components",
    "accordion",
    "custom-elements",
    "storybook"
  ]
}