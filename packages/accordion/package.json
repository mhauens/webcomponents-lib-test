{
  "name": "@mhauens/accordion",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "description": "Accordion web component package for the mhauens workspace.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
